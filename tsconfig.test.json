{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": ".tmp-tests"
  },
  "include": [
    "tests/**/*.ts",
    "src/config.ts",
    "src/types.ts",
    "src/data/**/*.ts",
    "src/engine/**/*.ts"
  ],
  "exclude": [
    "src/components/**",
    "src/hooks/**",
    "src/main.tsx",
    "src/App.tsx"
  ]
}
